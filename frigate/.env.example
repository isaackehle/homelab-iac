# Copy to .env and fill in real values. .env itself must be gitignored —
# only .env.example is committed.

FRIGATE_MQTT_HOST=
FRIGATE_MQTT_USER=
FRIGATE_MQTT_PASSWORD=

# If all cameras share one login (common for same-brand batches), one
# user/password pair is enough. If they don't, add per-camera variables
# here (e.g. FRIGATE_FRONTDOOR_USER) and reference them individually in
# config.yml instead of the shared {FRIGATE_RTSP_USER}/{FRIGATE_RTSP_PASSWORD}.
FRIGATE_RTSP_USER=
FRIGATE_RTSP_PASSWORD=
