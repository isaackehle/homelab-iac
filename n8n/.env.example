# Copy this file to `.env` in the same directory as docker-compose.yml
# (or paste these into Portainer's Stack "Environment variables" section)
# and fill in real values. Never commit the real .env file.

# System timezone, e.g. America/New_York — used by both n8n and browserless
TZ=America/New_York

# Your Tailscale tailnet's domain suffix, used to build n8n's WEBHOOK_URL
# (e.g. tailnet-name.ts.net — check the Tailscale admin console under DNS)
TS_TAILNET_DOMAIN=your-tailnet-name.ts.net

# Fresh Tailscale auth key for the n8n-ts sidecar node.
# Generate one at https://login.tailscale.com/admin/settings/keys
# Recommended: reusable + ephemeral=false, tagged if you use ACL tags
TS_AUTHKEY_N8N=tskey-auth-changeme

# Encrypts n8n's stored credentials at rest. Generate once and keep it
# stable — rotating this after n8n has stored credentials will make them
# unreadable. Generate with: openssl rand -hex 24
N8N_ENCRYPTION_KEY=changeme

# Basic auth for the n8n web UI
N8N_BASIC_AUTH_USER=changeme
N8N_BASIC_AUTH_PASSWORD=changeme
